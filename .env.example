# =============================================================================
# PaperPilot Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Application ---
APP_NAME=PaperPilot
APP_VERSION=0.1.0
DEBUG=false

# --- AI / LLM (required) ---
# Get your free API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# --- Database ---
# For SQLite (development):
DATABASE_URL=sqlite+aiosqlite:///paperpilot.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://paperpilot:paperpilot@localhost:5432/paperpilot

# --- File Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

# --- Auth / JWT (required) ---
# Generate a secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here

# --- OCR ---
OCR_LANGUAGES=en
# OCR_GPU=false
