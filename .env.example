# =============================================================================
# PaperPilot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Application -----------------------------------------------------------
APP_NAME=PaperPilot
APP_VERSION=0.1.0
DEBUG=False

# --- AI / LLM (required) ---------------------------------------------------
# Get your Google Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key-here"
# Optional: model override (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# --- Database --------------------------------------------------------------
# Default: SQLite for local development
# DATABASE_URL=sqlite+aiosqlite:///paperpilot.db
#
# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/paperpilot

# --- File Uploads ----------------------------------------------------------
# UPLOAD_DIR=uploads
# MAX_UPLOAD_SIZE_MB=20

# --- OCR -------------------------------------------------------------------
# Comma-separated language codes
# OCR_LANGUAGES=en
# Enable GPU acceleration for EasyOCR (requires CUDA)
# OCR_GPU=False

# --- Auth / JWT -----------------------------------------------------------
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET="your-256-bit-secret-here"
