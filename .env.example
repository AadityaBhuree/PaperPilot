# ===========================================
# PaperPilot Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# App
APP_NAME=PaperPilot
APP_VERSION=0.1.0
DEBUG=False

# AI / LLM — Required for evaluation features
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Database — defaults to local SQLite
DATABASE_URL=sqlite+aiosqlite:///paperpilot.db

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

# OCR
OCR_LANGUAGES=en
OCR_GPU=False
